# Copy to .env in backend/ or set in shell.
# Local dev (Postgres/Redis on host or published from Docker):
ICU_DATABASE_URL=postgresql+asyncpg://icu:icu@localhost:5432/icu
ICU_DATABASE_URL_SYNC=postgresql+psycopg://icu:icu@localhost:5432/icu
ICU_REDIS_URL=redis://localhost:6379/0
# Inside Docker Compose the api service overrides these to hostnames postgres / redis (see docker-compose.yml).

ICU_JWT_SECRET=change-me-to-a-long-random-string-in-production
ICU_JWT_ALGORITHM=HS256
ICU_ACCESS_TOKEN_EXPIRE_MINUTES=30
ICU_REFRESH_TOKEN_EXPIRE_DAYS=30

ICU_OTP_PEPPER=change-me-otp-pepper
ICU_OTP_TTL_SECONDS=600
ICU_OTP_COOLDOWN_SECONDS=60
ICU_OTP_MAX_PER_HOUR=5
ICU_OTP_MAX_ATTEMPTS=5
ICU_OTP_LOCK_SECONDS=900

ICU_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dev: also return OTP in API response when true
ICU_DEV_LOG_OTP=true

# Optional: Resend.com — if set, OTP is emailed (see https://resend.com)
# ICU_RESEND_API_KEY=re_...
# ICU_RESEND_FROM_EMAIL=ICU <onboarding@yourdomain.com>

# ICU_LOG_JSON=false
